      "boundElements": null,
      "updated": 1773007438731,
      "link": null,
      "locked": false,
      "text": "Brief chosen: Flashcard app\n\nCore idea: ai-generated flashcard study decks for any topic\n\nMVP goal: For us to enter a topic, generate a deck, study \nthe cards, and then mark each one as either clueless, \nsemi-understanding, or locked in.\n\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Brief chosen: Flashcard app\n\nCore idea: ai-generated flashcard study decks for any topic\n\nMVP goal: For us to enter a topic, generate a deck, study \nthe cards, and then mark each one as either clueless, \nsemi-understanding, or locked in.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
